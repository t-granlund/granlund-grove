{
  "ci": {
    "collect": {
      "url": [
        "http://127.0.0.1:4173/",
        "http://127.0.0.1:4173/about",
        "http://127.0.0.1:4173/career",
        "http://127.0.0.1:4173/work",
        "http://127.0.0.1:4173/ventures",
        "http://127.0.0.1:4173/resume",
        "http://127.0.0.1:4173/contact",
        "http://127.0.0.1:4173/privacy",
        "http://127.0.0.1:4173/colophon"
      ],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
